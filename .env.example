# =============== Database (MySQL) ===============
DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_URL=jdbc:mysql://localhost:3306/your_database_name
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# =============== JPA/Hibernate 설정 ===============
JPA_DDL_AUTO=update                    # 스키마 관리: create/create-drop/update/validate/none
JPA_STORAGE_ENGINE=innodb              # MySQL 스토리지 엔진
JPA_FORMAT_SQL=true                    # SQL 포맷팅 (개발: true, 운영: false)
JPA_SHOW_SQL=true                      # SQL 콘솔 출력 (개발: true, 운영: false)
JPA_USE_SQL_COMMENTS=true              # SQL 주석 포함 (개발: true, 운영: false)

# =============== JWT 인증 ===============
JWT_SECRET=your_jwt_secret_key_here    # JWT 서명용 비밀키 (256bit 이상 권장)
JWT_ACCESS_TOKEN_VALID=3600            # 액세스 토큰 유효시간 (초 단위, 예: 3600 = 1시간)
JWT_REFRESH_TOKEN_VALID=604800         # 리프레시 토큰 유효시간 (초 단위, 예: 604800 = 7일)

# =============== 로깅 설정 ===============
LOGGING_LEVEL_ROOT=info                      # 전체 로그 레벨 (trace/debug/info/warn/error)
LOGGING_LEVEL_AUTOCONFIGURE=warn             # Spring Boot 자동설정 로그
LOGGING_LEVEL_SQL=debug                      # Hibernate SQL 로그
LOGGING_LEVEL_SQL_PARAM=info                 # SQL 파라미터 바인딩 로그
LOGGING_LEVEL_SECURITY=info                  # Spring Security 로그
LOGGING_LEVEL_WEB=info                       # 웹 요청/응답 로그
LOGGING_LEVEL_TRANSACTION=info               # 트랜잭션 로그
LOGGING_LEVEL_APP=debug                      # 애플리케이션 패키지 로그


